# Instagram Graph API
INSTAGRAM_BUSINESS_ID=
INSTAGRAM_ACCESS_TOKEN=

# Discord notifications
DISCORD_WEBHOOK_URL=

# Google Places / Maps discovery
GOOGLE_PLACES_API_KEY=

# Canva MCP runs via the configured MCP client/server.
# OAuth is handled by the MCP host, not this .env file.
CANVA_MAX_ATTEMPTS=2

# Runtime
TZ=Australia/Melbourne
